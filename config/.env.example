# Trading Analytics Platform - Environment Variables

# Feature Flags
USE_MOCK_INTERNAL=true
USE_MOCK_EXTERNAL=true

# BigQuery Configuration
BIGQUERY_PROJECT=your-project-id
BIGQUERY_DATASET=your-dataset-name
BIGQUERY_CREDENTIALS_PATH=/path/to/service-account-key.json

# External API Keys
COINGECKO_API_KEY=your-coingecko-api-key
BLOOMBERG_API_KEY=your-bloomberg-api-key

# LLM Configuration
LLM_MODEL=gemini-pro
LLM_PROVIDER=vertex-ai
LLM_API_KEY=your-llm-api-key
